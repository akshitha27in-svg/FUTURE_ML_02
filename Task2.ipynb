   "cell_type": "markdown",
   "id": "ec33a178",
   "metadata": {},
   "source": [
    "# TF-IDF Feature Extraction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "2c03d2f3",
   "metadata": {},
   "outputs": [],
   "source": [
    "vectorizer = TfidfVectorizer(\n",
    "    stop_words='english',\n",
    "    max_features=5000\n",
    ")\n",
    "\n",
    "X = vectorizer.fit_transform(df['ticket_text'])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f8b6e263",
   "metadata": {},
   "source": [
    "# Category Classification"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "ab014edc",
   "metadata": {},
   "outputs": [],
   "source": [
    "y_category = df['Ticket Type']"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2b9ccb3b",
   "metadata": {},
   "source": [
    "Training test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "a247f3d4",
   "metadata": {},
   "outputs": [],
   "source": [
    "y_category = df['Ticket Type']\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X,\n",
    "    y_category,\n",
    "    test_size=0.2,\n",
    "    random_state=42\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b5488b63",
   "metadata": {},
   "source": [
    "# Train model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "de0df65c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Accuracy: 0.2328519855595668\n"
     ]
    }
   ],
   "source": [
    "category_model = LogisticRegression(\n",
    "    max_iter=1000\n",
    ")\n",
    "\n",
    "category_model.fit(X_train, y_train)\n",
    "\n",
    "# prediction\n",
    "cat_pred = category_model.predict(X_test)\n",
    "\n",
    "# accuracy\n",
    "print(\n",
    "    \"Accuracy:\",\n",
    "    accuracy_score(y_test, cat_pred)\n",
    ")"
   ]
  },
